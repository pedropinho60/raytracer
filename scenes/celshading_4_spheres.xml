<RT3>
    <lookat look_from="0 4.5 -15" look_at="0 0 1" up="0 1 0" />
    <camera type="perspective" fovy="45" /> 
    <!-- <lookat look_from="0 10 2" look_at="0 1 2" up="0 0 1" /> -->
    <!-- <camera type="orthographic" screen_window=" -16 16 -10 10" />  -->
    <!-- <integrator type="cel_shading" mapping_interval="20 35 65 85" /> -->
    <integrator type="cel_shading" mapping_interval="5 35 75" />
    <film type="image" w_res="1920" h_res="1200" filename="cel_shading_spheres_gc.png" img_type="png" gamma_corrected="true" />
    <!-- <film type="image" w_res="1920" h_res="1200" filename="cel_shading_spheres.png" img_type="png" gamma_corrected="false" /> -->
    <!-- Objects storage -->
    <aggregator type="list"/>
    <!-- The Scene -->
    <world_begin/>
        <!-- The Background -->
        <background type="4_colors" bl="176 214 175" tl="4 99 202" tr="4 99 202" br="176 214 175" />
        <!-- Lights -->
        <light_source type="ambient" I="0.1 0.1 0.1" scale="1 1 1" />
        <!-- <light_source type="directional" I="0.9 0.9 0.9" scale="0.4 0.4 0.4" from="1 1.45 -3" to="0 0 1" /> -->
        <light_source type="point" I="0.95 0.9 0.8" scale="0.4 0.4 0.4" from="0.1 4.0 1" />
        <!-- Material Library -->
        <make_named_material type="cel" name="green" ambient="0.4 0.4 0.4" shadow_color="0 40 0" silhouette_color="0 0 0" silhouette_angle="75" color_map="0 55 0  0 75 0  0 152 0  0 254 0  51 255 51" />
        <make_named_material type="cel" name="grey" ambient="0.1 0.1 0.1" shadow_color="40 40 40" silhouette_color="0 0 0" silhouette_angle="89.85" color_map="100 100 100" />

        <!-- Objects -->
        <named_material name="green"/>
        <object type="sphere" center="0 1 0" radius="1" />
        <object type="sphere" center="-5 1 4" radius="1" />
        <object type="sphere" center="2 1 5" radius="1" />
        <object type="sphere" center="6 2.7 -1" radius="1.3" />

        <named_material name="grey"/>
        <object type="plane" point="0 0 0" normal="0 1 0" />

    <world_end/>
</RT3>
